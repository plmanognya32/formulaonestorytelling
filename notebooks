        "def get_timing_tower(lap_number):\n",
        "    lap_data = []\n",
        "\n",
        "    for driver in session.drivers:\n",
        "        driver_laps = session.laps.pick_driver(driver)\n",
        "        lap = driver_laps[driver_laps['LapNumber'] == lap_number]\n",
        "\n",
        "        if lap.empty:\n",
        "            continue\n",
        "\n",
        "        lap_data.append({\n",
        "            'driver':      driver,\n",
        "            'position':    lap['Position'].iloc[0],\n",
        "            'lap_time':    lap['LapTime'].iloc[0],\n",
        "            'compound':    lap['Compound'].iloc[0],\n",
        "            'tyre_life':   lap['TyreLife'].iloc[0],\n",
        "            'stint':       lap['Stint'].iloc[0],\n",
        "            'cumulative_time':    lap['Time'].iloc[0],\n",
        "            'pit_in':      lap['PitInTime'].iloc[0],\n",
        "            'pit_out':     lap['PitOutTime'].iloc[0],\n",
        "        })\n",
        "\n",
        "    df = pd.DataFrame(lap_data).sort_values('position').reset_index(drop=True)\n",
        "\n",
        "    leader_cumulative_time = df.iloc[0]['cumulative_time']\n",
        "    df['gap_to_leader'] = df['cumulative_time'] - leader_cumulative_time\n",
        "\n",
        "    # Interval = gap to the car directly ahead (just the diff between adjacent rows)\n",
        "    df['interval'] = df['gap_to_leader'].diff().fillna(pd.Timedelta(seconds=0))\n",
        "\n",
        "    # Flag who's currently in the pit lane\n",
        "    df['in_pit'] = df['pit_in'].notna() & df['pit_out'].isna()\n",
        "\n",
        "    return df\n",
        "\n",
        "# Test it on lap 30\n",
        "tower = get_timing_tower(30)\n",
        "tower[['driver','position','compound','tyre_life','gap_to_leader','interval','in_pit']]"
      ],
